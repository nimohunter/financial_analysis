# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# SEC EDGAR — required, or you get 403s
SEC_USER_AGENT_EMAIL=your_email@example.com

# Postgres (read-write, used by ingestion pipeline)
DATABASE_URL=postgresql://finagent:password@postgres:5432/finagent

# Postgres (read-only, used by chat backend)
READONLY_DATABASE_URL=postgresql://readonly:password@postgres:5432/finagent

# Postgres connection details (used by DB init script)
POSTGRES_DB=finagent
POSTGRES_USER=finagent
POSTGRES_PASSWORD=password
READONLY_USER=readonly
READONLY_PASSWORD=password
